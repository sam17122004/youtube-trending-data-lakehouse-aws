{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3FullAccess",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:PutObject",
                "s3:ListBucket",
                "s3:DeleteObject"
            ],
            "Resource": [
                "arn:aws:s3:::yt-data-pipeline-brinze-us-east-1-dev/*",
                "arn:aws:s3:::yt-data-pipeline-brinze-us-east-1-dev",
                "arn:aws:s3:::yt-data-pipeline-sil-us-east-1-dev/*",
                "arn:aws:s3:::yt-data-pipeline-sil-us-east-1-dev",
                "arn:aws:s3:::yt-data-pipeline-aurium/*",
                "arn:aws:s3:::yt-data-pipeline-aurium",
                "arn:aws:s3:::yt-data-pipeline-scripts-sam/*",
                "arn:aws:s3:::yt-data-pipeline-scripts-sam"
            ]
        }
    ]
}